# Database
POSTGRES_USER=coachai
POSTGRES_PASSWORD=coachai_dev
POSTGRES_DB=coachai
DATABASE_URL=postgresql+asyncpg://coachai:coachai_dev@postgres:5432/coachai

# Redis
REDIS_PASSWORD=redis_dev
REDIS_URL=redis://:redis_dev@redis:6379/0

# Auth (Supabase)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# Judge service
JUDGE_URL=http://judge:8001
JUDGE_SECRET=judge_internal_secret

# App
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
